# ignore everything
*

# except gitignore and readme
!.gitignore
!README.md

# and setup script
!setup.sh

# and theme utility
!catppuccin
!catppuccin/**/*

# and relevant dotfiles

# -> zsh config
!.zshrc

# -> terminal emulator config
!wezterm
!wezterm/**/*

# -> editor config
!nvim
!nvim/**/*
nvim/lazy-lock.json

# -> firefox config
!firefox
!firefox/**/*

# -> ideavim config
!.ideavimrc

# -> tmux config
!tmux
!tmux/**/*
!.tmux.conf

# -> aerospace config
!aerospace
!aerospace/**/*
aerospace/aerospace.toml

# -> borders config
!borders
!borders/bordersrc

# -> sketchybar config
!sketchybar
!sketchybar/**/*

# -> lf config
!lf
!lf/**/*

# ignore .DS_Store in tracked dirs
**/.DS_Store

# ignore generated theme files
theme.edn
tmux/theme.conf
wezterm/theme.lua
nvim/lua/current-theme.lua
sketchybar/theme_colors.sh
sketchybar/theme_colors.edn
borders/theme_colors.sh
